{
  "name": "@clawheart/local-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "dev:renderer": "npm run dev --prefix frontend -- --port 5199 --strictPort",
    "dev:electron": "cross-env NODE_ENV=development ELECTRON_DEV=true electron src/main.js",
    "dev": "concurrently -k -n renderer,electron -c cyan,green \"npm run dev:renderer\" \"npm run dev:electron\"",
    "start": "electron src/main.js",
    "postinstall": "node scripts/setup-openclaw.js",
    "rebuild:native": "electron-builder install-app-deps",
    "ensure-node": "node scripts/ensure-bundled-node.js",
    "sync-brand-icon": "node scripts/sync-brand-icon-from-png.js",
    "build": "node scripts/build.js",
    "build:win-no-openclaw": "node scripts/build.js no-openclaw",
    "build:win-no-openclaw-dir": "node scripts/build.js no-openclaw dir",
    "build:dir": "node scripts/build.js dir",
    "build:mac": "node scripts/build.js mac",
    "build:mac-arm64": "node scripts/build.js mac arm64",
    "build:mac-no-openclaw": "node scripts/build.js mac no-openclaw",
    "build:mac-arm64-no-openclaw": "node scripts/build.js mac arm64 no-openclaw",
    "build:mac-no-openclaw-dir": "node scripts/build.js mac no-openclaw dir",
    "pack": "node scripts/build.js dir"
  },
  "description": "ClawHeart Desktop Client",
  "author": "ClawHeart Team",
  "dependencies": {
    "axios": "^1.13.6",
    "express": "^5.2.1",
    "openclaw": "^2026.3.13",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "png2icons": "^2.0.1"
  },
  "build": {
    "appId": "com.clawheart.desktop",
    "productName": "ClawHeart Desktop",
    "icon": "build/icon.png",
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*"
    ],
    "directories": {
      "output": "build-output"
    },
    "files": [
      "src/**/*",
      "frontend/dist/**/*",
      "build/icon.png",
      "build/icon.ico",
      "scripts/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "bundled/win-x64/node.exe",
          "to": "node.exe"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "scripts/nsis/refresh-shortcut-icons.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ClawHeart Desktop",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "extraResources": [
      {
        "from": "node_modules/openclaw",
        "to": "openclaw",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
